# Lark Open Platform credentials (required for e2e tests)
# Create an app at https://open.larksuite.com/app
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat ID to send test cards to.
# The bot must be added to this chat first.
# You can get the chat_id from the Lark API or by inspecting group chat info.
LARK_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
